# ── Required ───────────────────────────────────────────────────────────────────
# Google AI — covers Gemini (course outline + quiz), Imagen 3 (memes), Veo 2 (videos)
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# YouTube Data API v3 — for finding the best supplementary video per chapter
# Enable at https://console.cloud.google.com  →  APIs & Services  →  YouTube Data API v3
YOUTUBE_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────────
# ElevenLabs — chapter song/jingle generation
# If not set, song field will be null in the response
# Get yours at https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────────
# Set to false to skip Veo video generation entirely (videos will return status: "disabled")
# Useful during development or if you don't have Veo API access
ENABLE_VEO=false


MODEL_NAME=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

MONGO_URI=

MONGO_DB=hackai
MONGO_COLLECTION=user_roadmaps

LLM_TIMEOUT_SEC=15
LLM_MAX_RETRIES=0
LOG_LEVEL=DEBUG

VOICE_MODEL = "gemini-2.5-flash-native-audio-preview-12-2025"

ROADMAP_MAX_MODULES=1
ROADMAP_MAX_CHAPTERS_PER_MODULE=1

TAVILY_API_KEY=
